n"}],"author":{"name":"CHEN","slug":"blog-author","avatar":"https://cjpnice-picture.oss-cn-hangzhou.aliyuncs.com/img/202109161140460.jpg","link":"/","description":"学无止境","socials":{"github":"https://github.com/cjpnice","twitter":"","stackoverflow":"","wechat":"","qq":"","weibo":"","zhihu":"","csdn":"","juejin":"","customs":{}}}},"next_post":{"title":"数据结构代码实现：二叉树排序树","uid":"60c424b0116ca0c7f0541d6df3017fff","slug":"DataStructure-BST","date":"2020-05-17T01:33:21.000Z","updated":"2020-05-19T14:18:15.000Z","comments":true,"path":"api/articles/DataStructure-BST.json","keywords":null,"cover":"https://cjpnice-picture.oss-cn-hangzhou.aliyuncs.com/img/20200517093515.png","text":"二叉排序树的定义typedef int KeyType; typedef struct BSTNode&#123; KeyType key; struct BSTNode *lchild,*rchild; &#125;BSTNode,*BiTree; 插入操作 每次插入从根结点开...","link":"","photos":[],"count_time":{"symbolsCount":"2.6k","symbolsTime":"2 mins."},"categories":[{"name":"数据结构","slug":"数据结构","count":11,"path":"api/categories/数据结构.json"}],"tags":[{"name":"数据结构","slug":"数据结构","count":11,"path":"api/tags/数据结构.json"},{"name":"C++","slug":"C","count":11,"path":"api/tags/C.json"},{"name":"考研","slug":"考研","count":11,"path":"api/tags/考研.json"}],"author":{"name":"CHEN","slug":"blog-author","avatar":"https://cjpnice-picture.oss-cn-hangzhou.aliyuncs.com/img/202109161140460.jpg","link":"/","description":"学无止境","socials":{"github":"https://github.com/cjpnice","twitter":"","stackoverflow":"","wechat":"","qq":"","weibo":"","zhihu":"","csdn":"","juejin":"","customs":{}}}}}